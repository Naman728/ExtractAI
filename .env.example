# Application
APP_NAME=ExtractAI
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3100

# Database (Neon example — use asyncpg ssl=require / psycopg sslmode=require)
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB?ssl=require
# DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql+asyncpg://extractai:extractai@localhost:5432/extractai
DATABASE_URL_SYNC=postgresql+psycopg://extractai:extractai@localhost:5432/extractai

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Guest quota
GUEST_JOB_LIMIT=3
GUEST_SESSION_EXPIRE_DAYS=7
BATCH_MAX_ADDRESSES=500
BATCH_GUEST_MAX_ADDRESSES=25

# Extraction / pipeline
EXTRACTOR_TYPE=basic
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/storage
PIPELINE_VERSION=1.0.0
STRATEGY_VERSION=1.0.0
SCHEMA_VERSION=1
PROFILE_VERSION=1.0.0
DISCOVERY_VERSION=1.0.0

# Scraping limits (used in later phases)
HTTP_TIMEOUT_SECONDS=30
PLAYWRIGHT_TIMEOUT_MS=30000
MAX_HTML_BYTES=5242880
MAX_REDIRECTS=5

# Rate limiting (enforced via Redis middleware)
RATE_LIMIT_GUEST_PER_MINUTE=10
RATE_LIMIT_AUTH_PER_MINUTE=60

USE_CELERY=true
FETCH_CASCADE_RETRY=true

# Brevo (https://app.brevo.com) — signup verification
# Prefer REST API key (xkeysib-…). SMTP keys (xsmtpsib-) also supported.
BREVO_API_KEY=
BREVO_SENDER_NAME=ExtractAI
BREVO_SENDER_EMAIL=
BREVO_SMTP_LOGIN=
BREVO_USE_SMTP=false
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
FRONTEND_PUBLIC_URL=http://localhost:3100
EMAIL_VERIFICATION_EXPIRE_HOURS=24
EMAIL_VERIFICATION_REQUIRED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8100
API_PORT=8100
FRONTEND_PORT=3100

# AI Understanding Engine (post-extraction — never scrapes)
AI_UNDERSTANDING_ENABLED=true
AI_UNDERSTANDING_ASYNC=true
LLM_PROVIDER=none
# LLM_PROVIDER=openai|gemini|anthropic|ollama|none
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4096
AI_MAX_INPUT_CHARS=24000
UNDERSTANDING_VERSION=1.0.0
# Keys — never commit real secrets
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
